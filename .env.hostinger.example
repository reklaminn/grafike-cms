APP_NAME="Grafike CMS"
APP_ENV=production
APP_DEBUG=false
APP_KEY=base64:CHANGE_ME
APP_URL=https://cms.example.com
APP_DOMAIN=cms.example.com

APP_CONTAINER_NAME=grafike_cms_app
QUEUE_CONTAINER_NAME=grafike_cms_queue
SCHEDULER_CONTAINER_NAME=grafike_cms_scheduler
REDIS_CONTAINER_NAME=grafike_cms_redis

APP_LOCALE=tr
APP_FALLBACK_LOCALE=tr
APP_FAKER_LOCALE=tr_TR

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

DB_CONNECTION=mariadb
DB_HOST=mariadb-admindb
DB_PORT=3306
DB_DATABASE=grafike_cms
DB_USERNAME=root
DB_PASSWORD=change_me

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_DOMAIN=.example.com
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

REDIS_PASSWORD=
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="Grafike CMS"

CMS_CACHE_ENABLED=true
CMS_CACHE_TTL=600
CMS_HOMEPAGE_ID=
CMS_FRONTEND_URL=https://www.example.com

GOOGLE_TAG_MANAGER_ID=
GOOGLE_ANALYTICS_ID=
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
